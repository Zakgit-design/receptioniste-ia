# Copier ce fichier en .env et remplacer par la vraie connexion PostgreSQL
# une fois la base de données créée (voir docs/architecture.md).
DATABASE_URL="postgresql://user:password@localhost:5432/receptionniste_ia?schema=public"

# Authentification (Clerk, voir docs/architecture.md) — à remplir une fois le
# compte Clerk créé (action fondateur en attente, voir docs/sprint-log.md).
# Tant qu'elles sont absentes, l'application tourne normalement, simplement
# sans authentification active (voir src/auth/config.ts).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Secret de signature du webhook Clerk (Dashboard Clerk > Webhooks > Endpoint
# .../api/webhooks/clerk), voir src/auth/webhook.ts.
CLERK_WEBHOOK_SIGNING_SECRET=""
